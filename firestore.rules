rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Guard defensivo: si el doc del usuario aún NO existe (usuario recién
    // autenticado que todavía no fue aprovisionado), userRole() devuelve null
    // en vez de tirar denial en cadena. Esto es clave en el flujo multitenant:
    // permite que el propio usuario cree su doc por primera vez.
    function userDocExists() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function userRole() {
      return userDocExists()
        ? get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol
        : null;
    }

    function isStaff() {
      return userRole() in ['chef_partner', 'gerente', 'admin', 'superadmin'];
    }

    function isAdmin() {
      return userRole() in ['admin', 'superadmin'];
    }

    function isSuperAdmin() {
      return userRole() == 'superadmin';
    }

    // --- usuarios (modelo GLOBAL: 1 doc por Firebase UID, cross-tenant) ---
    // El propio usuario siempre puede leer y escribir SU propio doc — esta
    // es la regla base que resuelve el flujo de login/auto-provisioning.
    // Encima se agregan los permisos operativos de staff/admin.
    match /usuarios/{userId} {
      // Regla base: usuario autenticado ↔ su propio doc.
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Permisos adicionales de personal del local (se combinan con OR).
      allow get: if isStaff();
      allow list: if isSignedIn() && userRole() in ['gerente', 'admin', 'superadmin'];
      allow update: if isAdmin();
      allow delete: if isAdmin();

      match /notificaciones/{notifId} {
        allow read, write: if isSelf(userId);
      }
    }

    // --- premios: catálogo público (se puede ver sin sesión), escritura solo admin ---
    match /premios/{premioId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- pending_stamps: el cliente crea el suyo; staff/admin confirman ---
    match /pending_stamps/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isStaff();
    }

    // --- canjes: cliente lee/crea los suyos; staff lee todos y marca redeemed ---
    match /canjes/{id} {
      allow read: if isSignedIn() &&
        (isStaff() || resource.data.clienteId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.clienteId == request.auth.uid;
      allow update: if isStaff() || (isSignedIn() && resource.data.clienteId == request.auth.uid);
    }

    // --- logs: append-only. Cliente autenticado puede crear (escaneo directo) y
    // leer los suyos; nadie edita/borra; admin lee todos. El Admin SDK ignora estas reglas. ---
    match /system_logs/{id} {
      allow read: if isStaff() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // --- vendors (locales del multitenant): lectura pública, escritura admin ---
    match /vendors/{vendorId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
